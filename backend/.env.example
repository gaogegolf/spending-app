# Database
DATABASE_URL=sqlite:///./spending_app.db
# For Postgres: postgresql://user:password@localhost:5432/spending_app

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Feature Flags
ENABLE_PDF_PARSING=true
ENABLE_LLM_CLASSIFICATION=true
ENABLE_FX_CONVERSION=true

# FX Rate API (Frankfurter - free, no API key required)
FX_RATE_API_URL=https://api.frankfurter.app

# Environment
ENVIRONMENT=development
